%   Document class settings [config]
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
\setlength{\parindent}{1cm}

\AtBeginDocument{
    \interlinepenalty=150
    \setlength{\abovedisplayskip}{0pt}
    \setlength{\belowdisplayskip}{0pt}
    \setlength{\abovedisplayshortskip}{0pt}
    \setlength{\belowdisplayshortskip}{0pt}
}

\DeclareOption{overrideTitles}{
    \renewcommand{\@docTitle}{\@title}
    \@latex@warning{Disabled uppercase titles.}
}

\DeclareOption{overrideChapters}{
    \titleformat{\chapter}[hang]{}{}{0pt}{
        \centering\realSingleSpace\ifdocBody CHAPTER \thechapter \\ \fi
    }{\raggedright\doublespacing}
    \@latex@warning{Disabled uppercase Chapters.}
    \chapterCapOfftrue
}

\DeclareOption{editMode}{
    \editModetrue
    \@latex@warning{Edit mode is currently enabled. Blue text is author comments, red text is editor comments. Remove `editMode' to hide when compiling.}
}

\ProcessOptions\relax


%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%   editMode Options [editConfig]
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
\newcommand{\authRemark}[1]{
    \ifeditMode{\color{blue} #1}
    \fi
}

\newcommand{\editRemark}[1]{
    \ifeditMode{\color{red} #1}
    \fi
}
