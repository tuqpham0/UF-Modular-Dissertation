%%  Notes by author:
%%      The purpose of this alternate class is to provide a method of making a
%%      modular dissertation file. The overall goal of this new class is to allow users to
%%      compile each chapter individually for easier proofreading and editing.
%%      This comes at the expense of a few niceties from the original class written by
%%      Jason Nowell. 
%%      
%%      In particular, for this set-up to work as cleanly as possible, we remove the
%%      autogenerated portions from the Dr. Nowell's class. Instead we place the
%%      autogenerated portions into their own \verb|\MakeStart| and \verb|\MakeEnd|
%%      commands which will run in your chosen main.tex.
%%      Furthermore, we break this into distinct private functions (which base LaTeX
%%      uses the @ symbol to hide along with a UF prefix.
%%      
%%      This set-up requires understanding of the `subfiles' system to allow for
%%      compilation of individual chapters. This should similarly work for the `standalone'
%%      class/package, but as this is a single project where every chapter included should use
%%      an umbrella preamble, standalone leads to unnecessary risks. This version is an oddball
%%      middle ground of fully automated (Jason's version) and one that is completely
%%      personalized (which doesn't exist, but probably would be some sort of \verb|standalone|
%%      set-up that pulls together each preamble automatically).
%%      
%%      This class file is more or less a copy/paste of Jason's, though with a few minor 
%%      changes:
%%          - Dissertation opening is sent a command that looks at the provided files instead
%%              of autogenerating. This allows subfiles to not contain the entire opening when
%%              compiling independently.
%%          - Similarly, the concluding sections are now not autogenerated either for similar
%%              reasons. (Though, one can make an argument for the bibliography to reduce
%%              warnings)
%%          - The core two large functions that automatically ran at the beginning/end of the
%%              document are broken down into smaller functions. This makes customization a bit
%%              easier to follow.
%%          - Revert the list of algorithms back to being algorithms. My dissertation did not
%%              have any types other than figures/tables/algorithms, so this suited my needs.
%%              Instead I've added a custom string for the user to change and it defaults to
%%              `Algorithm'.
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{ufdm}[v2026 UF Dissertation supporting Subfiles]

\LoadClass[12pt]{report}%   Underlying documentclass is "report".
\usepackage{setspace} %     Always before hyperref -- Enable correct footnote link
\usepackage[colorlinks=true]{hyperref}  % 

%%      Redefine \@chapter to remove unnecessary gaps. This applies to Appendices as well.
\def\@chapter[#1]#2{
    \ifnum \c@secnumdepth > \m@ne
        \if@mainmatter
            \refstepcounter{chapter}%
            \typeout{\@chapapp\space\thechapter.}%
            \addcontentsline{toc}{chapter}{\protect\numberline{\!\MakeUppercase{\@chapapp}\hphantom{ }\thechapter}#1}%
        \else
            \addcontentsline{toc}{chapter}{#1}%
        \fi
    \else
        \addcontentsline{toc}{chapter}{#1}%
    \fi
    \chaptermark{#1}%
    \if@twocolumn
        \@topnewpage[\@makechapterhead{#2}]%
    \else
        \@makechapterhead{#2}%
        \@afterheading
    \fi
}
\renewcommand{\numberline}[1]{#1~}
