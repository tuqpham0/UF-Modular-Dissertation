%   New `if' settings
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%%      Determines if the actual document body has begun. Default to false, set to true after
%%      our \verb|\MakeDissertationOp| command, set back to false for closing pages as well.
\newif\ifdocBody
    \docBodyfalse
%%      Option to override autocapitalization of your title (i.e. your object is written
%%      classically with a lowercase)
\newif\iftitleCapOff
    \titleCapOfffalse
%%      Similarly, but for chapter headers instead
\newif\ifchapterCapOff
    \chapterCapOfffalse
%%      editMode is an option to display extra warnings/info/author/reviewer comments
%%      Use [editmode] option to turn it on
\newif\ifeditMode
    \editModefalse
    
%%      asks if there is more than 1 appendix. This will in turn alter the behavior of \appendix
\newif\ifmultipleAppendix
    \multipleAppendixfalse
    
%%      Do you want a List of Tables/Figures/Objects
%%      MAKERNOTE: Jason wanted a per table value. Potentially able to implement. But am lazyyyy
\newif\ifhaveTables
    \haveTablesfalse
\newif\ifhaveFigures
    \haveFiguresfalse
\newif\ifhaveAlgorithms
    \haveAlgorithmsfalse
\newif\ifhaveObjects
    \haveObjectsfalse



%%      Set up for appendix system.
\newif\ifhaveAppendix
    \haveAppendixfalse
    
\let\oldappendix\appendix

\renewcommand{\appendix}{
    \oldappendix
    \haveAppendixtrue
    \let\oldChapter\chapter %% store old \chapter behavior into \oldChapter. We will swap back later if in \makeEnd if necessary
    \ifmultipleAppendix
        %% If there are multiple appendices, then appendices should be titled: Appendix {\Alpha{\thechapter}} {Appendix name}
    
        %% Changes ToC behavior to Appendix \Alpha{\theChapter}
        \titleformat{\chapter}[hang]
            {\uppercase}{}{0pt}
            {\centering\realSingleSpace Appendix {\thechapter}\hphantom{ }}
        %% Fixes some spacing for the ToC without adjusting the Chapters
        \titlecontents{chapter}[2em]
            {\addvspace{8pt}}
            {%
                {\hspace*{-2em}\hyper@linkstart{link}{\Hy@tocdestname}\hspace*{2em}
                {\contentslabel{2em}\hspace{4em}}\hyper@linkend}%
                \ifchapterCapOff\else\color{blue}\uppercase\fi
            }{}%
            {\hyper@linkstart{link}{\Hy@tocdestname}{\titlerule*[5pt]{.}\thecontentspage}\hyper@linkend \\*\addvspace{8pt}}
    \else
    %% Else, it should just be Appendix {Appendix name}
        \titlecontents{chapter}[0em]
            {\addvspace{8pt}}
            {\hspace*{-2em}\hyper@linkstart{link}{\Hy@tocdestname}\hspace*{2em}{APPENDIX: }\hyper@linkend%
            \ifchapterCapOff\else\color{blue}\uppercase\fi}
            {}
            {\hyper@linkstart{link}{\Hy@tocdestname}{\titlerule*[5pt]{.}\thecontentspage}\hyper@linkend \\*}
        
        \titleformat{\chapter}[hang]
            {\uppercase}
            {}
            {0pt}
            {\centering\realSingleSpace Appendix\hphantom{ }}
            [\raggedright\doublespacing]
    \fi
}

    

