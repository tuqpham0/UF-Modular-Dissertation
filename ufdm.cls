%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%   Ending pages
%%      Bibliography
\providecommand{\@UFreferences}{
    \ifExists{referenceFile}{
        \setcounter{secnumdepth}{-1}

        \renewcommand{\bibname}{LIST OF REFERENCES\vspace{1\baselineskip}}
        \phantomsection
        \clearpage
        \addcontentsline{toc}{chapter}{LIST OF REFERENCES}
        \label{end:references}
        \bibliographystyle{\referenceStyle}
        \interlinepenalty=10000
        {\singlespacing\bibliography{\referenceFile}}
    }{\@latex@warning{You have not specified your reference file. If unintentional, use \setReferenceFile{bibFile}{bibStyle}}}\clearpage
    \phantomsection
}

%%      Biography
\providecommand{\@UFbiographic}{
    \ifExists{biographicalFile}{
        \setcounter{secnumdepth}{-1}
        \chapter{BIOGRAPHICAL SKETCH}
        \label{end:biography}

        \interlinepenalty=150
        \input{\biographicalFile}
    }{\@latex@warning{You have not specified a biography file. If unintentional, use \setBiographicalFile.}}
}
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%   Paper formatting :: Chapters/Appendices/MakeStart/MakeEnd
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%%      Combine functions to make disseration opening
\providecommand{\makeStart}{
    \maketitle
    
    \newpage
    \@UFcopyright
    \newpage
    
    \@UFdedication

    \@UFacknowledgments
    
    \@UFLists

    \newpage
    \@UFabstract

    % \addtocontents{toc}{\protect\contentsline{part}{CHAPTER}{}{}}%
    \setcounter{secnumdepth}{5}
    \docBodytrue
    
    \titlecontents{chapter}[2em]
        {\addvspace{8pt}}
        {%
            {\hspace*{-2em}\hyper@linkstart{link}{\Hy@tocdestname}\hspace*{2em}
            {\contentslabel{2em}\hspace{3.5em}}\hyper@linkend}%
            \ifchapterCapOff\else\color{blue}\uppercase\fi
        }{}%
        {\hyper@linkstart{link}{\Hy@tocdestname}{\titlerule*[5pt]{.}\thecontentspage}\hyper@linkend \\*\addvspace{8pt}}
    
    \setlength{\abovedisplayskip}{0pt}
    \setlength{\belowdisplayskip}{0pt}
    \setlength{\abovedisplayshortskip}{0pt}
    \setlength{\belowdisplayshortskip}{0pt}
}

%%      Combine functions to make disseration ending
\providecommand{\makeEnd}{
    \docBodyfalse
    \ifhaveAppendix
    %%  Reset behaviors back to chapters/\verb|\makeStart| styles
        \let\chapter\oldChapter
        \titleformat{\chapter}[hang]
        {\uppercase}{}{0pt}{\centering\realSingleSpace\ifdocBody CHAPTER \thechapter \fi}[\raggedright\doublespacing]
    \fi
    %%  Fix some indentation problems in the ToC for Bibliography and biography
    \titlecontents{chapter}[0em]
        {\addvspace{8pt}}
        {%
            {\hspace*{-2em}\hyper@linkstart{link}{\Hy@tocdestname}\hspace*{2em}{\contentslabel{2em}}\hyper@linkend}%
            \ifchapterCapOff\else\color{blue}\uppercase\fi
        }{}%
        {\hyper@linkstart{link}{\Hy@tocdestname}{\titlerule*[5pt]{.}\thecontentspage}\hyper@linkend \\*\addvspace{8pt}}
    
    \@UFreferences

    \@UFbiographic
}


