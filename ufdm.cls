%   User Configuration Commands [config]
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%%      Assigns files to variable names and connects to the appropriate macro
\providecommand{\setCopyrightFile}[2][tex]{
    \edef\copyrightFile{#2.#1}
}
    
\providecommand{\setDedicationFile}[2][tex]{
    \edef\dedicationFile{#2.#1}
}
    
\providecommand{\setAcknowledgmentsFile}[2][tex]{
    \edef\acknowledgmentsFile{#2.#1}
}
    
\providecommand{\setAbbreviationsFile}[2][tex]{
    \edef\abbreviationsFile{#2.#1}
}
    
\providecommand{\setAbstractFile}[2][tex]{
    \edef\abstractFile{#2.#1}
}

%  We assume anyone using LaTeX will use BibTeX unless they specify otherwise. 
%  The second argument sets the .bst file that should hold the bibtex style file.
\providecommand{\setReferenceFile}[2]{
    \edef\referenceFile{#1}
    \edef\referenceStyle{#2}
}
    
\providecommand{\setBiographicalFile}[2][tex]{ 
    \edef\biographicalFile{#2.#1}
}

%%      Assigns macros for the title page
\providecommand{\thesisType}[1]{
    \providecommand{\@ThesisType}{#1}
}% Dissertation or Thesis would be the expected values
    
\providecommand{\degreeType}[1]{ 
    \providecommand{\@DegreeType}{#1}
}% Masters of * or Doctorate of Philosophy etc would be the expected text here.
    
\providecommand{\degreeYear}[1]{
    \providecommand{\@DegreeYear}{#1}
}% Almost certainly this would be the current year.
    
\providecommand{\chair}[2][]{ 
    \providecommand{\@Chair}{#2}
    \if\relax\detokenize{#1}\relax
    % Test if the optional argument is given.
    \else
    %  If it wasn't given we do nothing. 
    %  If it is given, then we will define a "cochair" command to hold the cochair name.
        \providecommand{\@CoChair}{#1}%
    \fi
}% This is the chair and takes an optional argument (default blank) for the cochair.

\providecommand{\degreeMonth}[1]{ 
    \providecommand{\@DegreeMonth}{#1}
}% December, May, or August

\providecommand{\major}[1]{
    \providecommand{\@Major}{#1}
}%            Provide the "Major" for the abstract.

%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%   Private functions
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%%      These functions will constitute the construction of the beginning and end of the dissertation. All files
%%      including will be supplied by the user. Jason built some nice wrappers for each portion to format them
%%      correctly. I just break apart his sections for easier editing:
%%          1. In case UF decides to reformat how their dissertations/theses look
%%          2. In case someone wants to learn from this more efficiently
%%%%%%%
%%      These will be combined into makeStart and makeEnd
% Title page, 
% copyright page, 
% dedication (if any), 
% acknowledgments, 
% table of contents, 
% list of tables (if any), 
% list of figures (if any), 
% list of abbreviations (if any), 
% academic abstract, 

% chapters \& appendices (if any), 

% list of references, 
% biographical sketch
%%%%%%%
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%   Opening pages
%%      Title page formatting
\providecommand{\@docTitle}{\MakeUppercase{\@title}}
\renewcommand{\maketitle}{%
    \begin{center}
        \thispagestyle{empty}%
        \vspace*{-0.4in}\realSingleSpace{\@docTitle}%
        \vfill%
        By\\*[\baselineskip]%
        \MakeUppercase{\@author}%
        \vfill%
        A \MakeUppercase{\@ThesisType}\ PRESENTED TO THE GRADUATE SCHOOL\\%
        OF THE UNIVERSITY OF FLORIDA IN PARTIAL FULFILLMENT\\%
        OF THE REQUIREMENTS FOR THE DEGREE OF \\%
        \MakeUppercase{\@DegreeType}\\*[\baselineskip]%
        UNIVERSITY OF FLORIDA\\*[\baselineskip]%
        \@DegreeYear%
    \end{center}
    \newpage
}

%%      Copyright page
\providecommand{\@UFcopyright}{
    \vspace*{\fill}
    \begin{center}
        \textcopyright{} \@DegreeYear{} \@author
    \end{center}
    \vspace*{\fill}
}
%%      Dedication
\providecommand{\@UFdedication}{
    \setcounter{secnumdepth}{-1}
    \ifExists{dedicationFile}{
        \vspace*{\fill}
        \begin{center}
            \realSingleSpace
            \input{\dedicationFile}
        \end{center}
        \vspace*{\fill}
    }{\@latex@warning{You are potentially missing a `Dedication' chapter. If unintentional, use the command \setDedicationFile.}}
}

%%      Acknowledgments
\providecommand{\@UFacknowledgments}{
\phantomsection
    \ifExists{acknowledgmentsFile}{
        \chapter{ACKNOWLEDGMENTS}
        
        \input{\acknowledgmentsFile}
    }{\@latex@warning{You are potentially missing an `Acknowledgments' chapter. If unintentional, use the command \setAcknowledgmentsFile.}}
}

%%      Table of Contents, List of Tables, List of Figures, List of Abbreviations squish
\providecommand{\@UFLists}{
    {\realSingleSpace \tableofcontents}

    \ifhaveTables
        {\realSingleSpace\listoftables}
        \addcontentsline{toc}{chapter}{LIST OF TABLES}
    \fi

    \ifhaveFigures
        {\realSingleSpace\listoffigures}
        \addcontentsline{toc}{chapter}{LIST OF FIGURES}
    \fi
    
    \ifhaveAlgorithms
        {\doublespacing\listofalgorithms}
        % \addcontentsline{toc}{chapter}{LIST OF ALGORITHMS}
    \fi
    
    \ifExists{abbreviationsFile}{
        \clearpage
        \phantomsection
        \chapter{LIST OF ABBREVIATIONS}\label{sec:abbr}
        \phantomsection
        \input{\abbreviationsFile}
    }{\@latex@warning{You are potentially missing an `Abbreviations' section. If unintentional, use the command \setAbbreviationsFile.}}
}

%%      Academic Abstract
\providecommand{\@UFabstract}{
    \phantomsection
    \addcontentsline{toc}{chapter}{ABSTRACT}
    \label{sec:abstract}
    \begin{center}\realSingleSpace
        Abstract of \@ThesisType\ Presented to the Graduate School \\
        of the University of Florida in Partial Fulfillment of the\\
        Requirements for the Degree of \@DegreeType\\[\baselineskip]

        \bgroup\@docTitle\egroup\\[\baselineskip]

        By\\[\baselineskip]

        \@author\\[\baselineskip]
        \@DegreeMonth\ \@DegreeYear
    \end{center}
    \bgroup{\realSingleSpace%
    \ifExists{@Chair}{%
        \noindent Chair: \@Chair
        
    }{\@latex@warning{You are missing a committee chair. If unintentional, use the command \chair.}}%
    \ifExists{@CoChair}{%
        \noindent CoChair: \@CoChair
        
    }{\@latex@warning{You may be missing a committee cochair. If unintentional, add the option to \chair.}}%
    \noindent Major: \@Major
    
    \egroup}
    
    \ifExists{abstractFile}{
        \input{\abstractFile}
    }{\@latex@warning{You are missing an `Abstract' section. If unintentional, use the command \setAbstractFile.}}
}
