\newcommand{\R}{\mathbb{R}}
\newcommand{\bd}{\partial}
\newcommand{\st}{\,:\,}
\newcommand{\edit}[1]{\textcolor{red}{\textbf{{#1}}}}
\newcommand{\cech}{{\v C}ech\ }

%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
%   Theorem/Lemma/Corollary environments
%-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-
\newtheorem{thm}{Theorem}[chapter]
    \renewcommand{\thethm}{\thechapter-\arabic{thm}}
\newtheorem{lem}{Lemma}[chapter]
    \renewcommand{\thelem}{\thechapter-\arabic{lem}}
\newtheorem{cor}{Corollary}[chapter]
    \renewcommand{\thecor}{\thechapter-\arabic{cor}}
\newtheorem{prop}{Proposition}[chapter]
    \renewcommand{\theprop}{\thechapter-\arabic{prop}}
\newtheorem{defi}{Definition}[chapter]
    \renewcommand{\thedefi}{\thechapter-\arabic{defi}}